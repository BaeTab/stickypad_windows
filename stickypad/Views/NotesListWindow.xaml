<Window
    x:Class="StickyPad.Views.NotesListWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:res="clr-namespace:StickyPad.Resources"
    xmlns:u="clr-namespace:StickyPad.Utils"
    xmlns:vm="clr-namespace:StickyPad.ViewModels"
    xmlns:m="clr-namespace:StickyPad.Models"
    Title="{x:Static res:Strings.NoteList_WindowTitle}"
    Width="640"
    Height="540"
    Background="#FAFAFA"
    FontFamily="Segoe UI"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="TabToggle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="14,4" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFEFEF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1976D2" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="20"
                FontWeight="SemiBold"
                Text="{x:Static res:Strings.NoteList_Title}" />
            <TextBlock
                Margin="10,0,0,0"
                VerticalAlignment="Center"
                Foreground="#666"
                Text="{Binding TotalCount, StringFormat={x:Static res:Strings.NoteList_TotalFormat}}" />
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Menu
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    Visibility="{Binding ShowTrash, Converter={StaticResource InverseBoolToVis}}">
                    <MenuItem
                        Padding="10,4"
                        Header="{x:Static res:Strings.NoteList_Export}"
                        ToolTip="{x:Static res:Strings.NoteList_ExportTooltip}">
                        <MenuItem Command="{Binding ExportHtmlCommand}" Header="{x:Static res:Strings.NoteList_ExportHtml}" />
                        <MenuItem Command="{Binding ExportPdfCommand}" Header="{x:Static res:Strings.NoteList_ExportPdf}" />
                        <Separator />
                        <MenuItem Command="{Binding ExportMarkdownFilesCommand}" Header="{x:Static res:Strings.NoteList_ExportMarkdownFiles}" />
                    </MenuItem>
                </Menu>
                <Button
                    Padding="12,4"
                    Command="{Binding NewNoteCommand}"
                    Content="{x:Static res:Strings.NoteList_NewNote}" />
            </StackPanel>
        </DockPanel>

        <DockPanel Grid.Row="1" Margin="0,12,0,0" LastChildFill="False">
            <!-- 선택 도구 (활성 탭에서만) -->
            <StackPanel
                DockPanel.Dock="Right"
                Orientation="Horizontal"
                Visibility="{Binding ShowTrash, Converter={StaticResource InverseBoolToVis}}">
                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Foreground="#666"
                    Text="{Binding SelectedCount, StringFormat={x:Static res:Strings.NoteList_SelectedFormat}}" />
                <Button
                    Margin="0,0,4,0"
                    Padding="8,3"
                    Command="{Binding SelectAllCommand}"
                    Content="{x:Static res:Strings.NoteList_SelectAll}"
                    Cursor="Hand" />
                <Button
                    Margin="0,0,4,0"
                    Padding="8,3"
                    Command="{Binding ClearSelectionCommand}"
                    Content="{x:Static res:Strings.NoteList_ClearSelection}"
                    Cursor="Hand" />
                <Menu
                    VerticalAlignment="Center"
                    Background="Transparent">
                    <MenuItem
                        Padding="8,3"
                        IsEnabled="{Binding HasSelection}">
                        <MenuItem.Header>
                            <TextBlock>
                                <Run Text="{x:Static res:Strings.Bulk_Actions}" /><Run Text=" ▾" />
                            </TextBlock>
                        </MenuItem.Header>
                        <MenuItem Command="{Binding BulkDeleteCommand}" Header="{x:Static res:Strings.Bulk_DeleteSelected}" />
                        <Separator />
                        <MenuItem Header="{x:Static res:Strings.Bulk_ChangeColor}">
                            <MenuItem Command="{Binding BulkSetColorCommand}" CommandParameter="{x:Static m:NoteColor.Yellow}" Header="Yellow" />
                            <MenuItem Command="{Binding BulkSetColorCommand}" CommandParameter="{x:Static m:NoteColor.Pink}" Header="Pink" />
                            <MenuItem Command="{Binding BulkSetColorCommand}" CommandParameter="{x:Static m:NoteColor.Blue}" Header="Blue" />
                            <MenuItem Command="{Binding BulkSetColorCommand}" CommandParameter="{x:Static m:NoteColor.Green}" Header="Green" />
                            <MenuItem Command="{Binding BulkSetColorCommand}" CommandParameter="{x:Static m:NoteColor.Purple}" Header="Purple" />
                            <MenuItem Command="{Binding BulkSetColorCommand}" CommandParameter="{x:Static m:NoteColor.Gray}" Header="Gray" />
                        </MenuItem>
                    </MenuItem>
                </Menu>
            </StackPanel>

            <ToggleButton
                Content="{x:Static res:Strings.NoteList_TabActive}"
                IsChecked="{Binding ShowTrash, Mode=OneWay, Converter={StaticResource InverseBool}}"
                Click="ActiveTab_OnClick"
                Style="{StaticResource TabToggle}" />
            <ToggleButton
                IsChecked="{Binding ShowTrash}"
                Style="{StaticResource TabToggle}">
                <TextBlock>
                    <Run Text="{x:Static res:Strings.NoteList_TabTrash}" />
                    <Run Foreground="#999" Text="{Binding TrashedCount, StringFormat={} ({0})}" />
                </TextBlock>
            </ToggleButton>
            <Button
                Margin="8,0,0,0"
                Padding="10,3"
                Background="#FBE9E7"
                BorderThickness="0"
                Command="{Binding EmptyTrashCommand}"
                Content="{x:Static res:Strings.NoteList_EmptyTrashButton}"
                Cursor="Hand"
                Visibility="{Binding ShowTrash, Converter={StaticResource BoolToVis}}" />
        </DockPanel>

        <TextBox
            x:Name="SearchBox"
            Grid.Row="2"
            Height="32"
            Margin="0,12,0,0"
            Padding="8,6"
            FontSize="14"
            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

        <ItemsControl
            Grid.Row="3"
            Margin="0,8,0,0"
            ItemsSource="{Binding Tags}"
            Visibility="{Binding ShowTrash, Converter={StaticResource InverseBoolToVis}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:TagFilter}">
                    <Button
                        Margin="0,0,6,6"
                        Padding="10,3"
                        Background="#EFEFEF"
                        BorderThickness="0"
                        Command="{Binding DataContext.SelectTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding Tag}"
                        Cursor="Hand">
                        <TextBlock>
                            <Run Text="#" /><Run Text="{Binding Tag}" />
                            <Run Foreground="#888" Text="{Binding Count, StringFormat={} {0}}" />
                        </TextBlock>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="4" Margin="0,12,0,0">
            <ListBox
                x:Name="NotesList"
                BorderThickness="0"
                HorizontalContentAlignment="Stretch"
                ItemsSource="{Binding Items}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,6" />
                    </Style>
                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:NoteSummary}">
                        <Border
                            Padding="12,10"
                            CornerRadius="6"
                            MouseLeftButtonUp="Card_OnMouseLeftButtonUp">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="White" />
                                    <Setter Property="BorderBrush" Value="#E5E5E5" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Background" Value="#EAF3FF" />
                                            <Setter Property="BorderBrush" Value="#1976D2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <CheckBox
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Margin="2,0,6,0"
                                    IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                    ToolTip="{x:Static res:Strings.NoteList_SelectForExportTooltip}"
                                    Visibility="{Binding IsTrashed, Converter={StaticResource InverseBoolToVis}}" />

                                <Rectangle
                                    Grid.Column="1"
                                    Width="4"
                                    HorizontalAlignment="Left"
                                    Fill="{Binding AccentBrush}"
                                    RadiusX="2"
                                    RadiusY="2" />

                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        TextTrimming="CharacterEllipsis"
                                        u:HighlightedText.Segments="{Binding TitleSegments}" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="12"
                                        Foreground="#666"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap"
                                        u:HighlightedText.Segments="{Binding ExcerptSegments}" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="11"
                                        Foreground="#1976D2"
                                        Visibility="{Binding TagsLine, Converter={StaticResource NonEmptyToVis}}"
                                        u:HighlightedText.Segments="{Binding TagSegments}" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="3"
                                    VerticalAlignment="Top"
                                    Orientation="Horizontal">
                                    <StackPanel Margin="0,2,8,0" HorizontalAlignment="Right">
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="#999"
                                            HorizontalAlignment="Right"
                                            Text="{Binding ModifiedAt, StringFormat=g}"
                                            Visibility="{Binding IsTrashed, Converter={StaticResource InverseBoolToVis}}" />
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="#B85C5C"
                                            HorizontalAlignment="Right"
                                            Text="{Binding DeletedAt, StringFormat={x:Static res:Strings.NoteList_DeletedAtFormat}}"
                                            Visibility="{Binding IsTrashed, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>

                                    <!-- 활성 카드: Delete (휴지통으로) -->
                                    <Button
                                        Padding="6,1"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Content="{x:Static res:Strings.NoteList_Delete}"
                                        Visibility="{Binding IsTrashed, Converter={StaticResource InverseBoolToVis}}" />

                                    <!-- 휴지통 카드: 복원 / 영구삭제 -->
                                    <Button
                                        Padding="6,1"
                                        Margin="0,0,4,0"
                                        Background="#E3F2FD"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Content="{x:Static res:Strings.NoteList_Restore}"
                                        Cursor="Hand"
                                        Visibility="{Binding IsTrashed, Converter={StaticResource BoolToVis}}" />
                                    <Button
                                        Padding="6,1"
                                        Background="#FBE9E7"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.PurgeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Content="{x:Static res:Strings.NoteList_PurgePermanently}"
                                        Cursor="Hand"
                                        Visibility="{Binding IsTrashed, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock
                Margin="0,40,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                FontSize="13"
                Foreground="#888"
                Text="{Binding EmptyMessage}"
                Visibility="{Binding Items.Count, Converter={StaticResource ZeroToVis}}" />
        </Grid>

        <DockPanel Grid.Row="5" Margin="0,8,0,0">
            <Button
                Padding="10,3"
                Command="{Binding ClearTagCommand}"
                Content="{x:Static res:Strings.NoteList_ClearTagFilter}"
                IsEnabled="{Binding ActiveTag, Converter={StaticResource NonNullToBool}}" />
            <TextBlock
                Margin="10,0,0,0"
                VerticalAlignment="Center"
                Foreground="#888"
                Text="{Binding ActiveTag, StringFormat={x:Static res:Strings.NoteList_TagFilterFormat}}" />
            <TextBlock
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Foreground="#888"
                Text="{x:Static res:Strings.NoteList_FooterHint}" />
        </DockPanel>
    </Grid>
</Window>
