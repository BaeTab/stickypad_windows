<Window
    x:Class="StickyPad.Views.NotesListWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:u="clr-namespace:StickyPad.Utils"
    xmlns:vm="clr-namespace:StickyPad.ViewModels"
    Title="StickyPad — All notes"
    Width="640"
    Height="540"
    Background="#FAFAFA"
    FontFamily="Segoe UI"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="TabToggle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="14,4" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFEFEF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1976D2" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="20"
                FontWeight="SemiBold"
                Text="All notes" />
            <TextBlock
                Margin="10,0,0,0"
                VerticalAlignment="Center"
                Foreground="#666"
                Text="{Binding TotalCount, StringFormat={}{0} total}" />
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Margin="0,0,6,0"
                    Padding="10,4"
                    Command="{Binding ExportTextCommand}"
                    Content="내보내기"
                    ToolTip="메모를 마크다운/텍스트 파일로 내보내기" />
                <Button
                    Padding="12,4"
                    Command="{Binding NewNoteCommand}"
                    Content="+ New note" />
            </StackPanel>
        </DockPanel>

        <StackPanel Grid.Row="1" Margin="0,12,0,0" Orientation="Horizontal">
            <ToggleButton
                Content="활성"
                IsChecked="{Binding ShowTrash, Mode=OneWay, Converter={StaticResource InverseBool}}"
                Click="ActiveTab_OnClick"
                Style="{StaticResource TabToggle}" />
            <ToggleButton
                IsChecked="{Binding ShowTrash}"
                Style="{StaticResource TabToggle}">
                <TextBlock>
                    <Run Text="휴지통" />
                    <Run Foreground="#999" Text="{Binding TrashedCount, StringFormat={} ({0})}" />
                </TextBlock>
            </ToggleButton>
            <Button
                Margin="8,0,0,0"
                Padding="10,3"
                Background="#FBE9E7"
                BorderThickness="0"
                Command="{Binding EmptyTrashCommand}"
                Content="휴지통 비우기"
                Cursor="Hand"
                Visibility="{Binding ShowTrash, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <TextBox
            x:Name="SearchBox"
            Grid.Row="2"
            Height="32"
            Margin="0,12,0,0"
            Padding="8,6"
            FontSize="14"
            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

        <ItemsControl
            Grid.Row="3"
            Margin="0,8,0,0"
            ItemsSource="{Binding Tags}"
            Visibility="{Binding ShowTrash, Converter={StaticResource InverseBoolToVis}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:TagFilter}">
                    <Button
                        Margin="0,0,6,6"
                        Padding="10,3"
                        Background="#EFEFEF"
                        BorderThickness="0"
                        Command="{Binding DataContext.SelectTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding Tag}"
                        Cursor="Hand">
                        <TextBlock>
                            <Run Text="#" /><Run Text="{Binding Tag}" />
                            <Run Foreground="#888" Text="{Binding Count, StringFormat={} {0}}" />
                        </TextBlock>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="4" Margin="0,12,0,0">
            <ListBox
                x:Name="NotesList"
                BorderThickness="0"
                HorizontalContentAlignment="Stretch"
                ItemsSource="{Binding Items}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,6" />
                    </Style>
                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:NoteSummary}">
                        <Border
                            Padding="12,10"
                            Background="White"
                            BorderBrush="#E5E5E5"
                            BorderThickness="1"
                            CornerRadius="6"
                            MouseLeftButtonUp="Card_OnMouseLeftButtonUp">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Rectangle
                                    Grid.Column="0"
                                    Width="4"
                                    HorizontalAlignment="Left"
                                    Fill="{Binding AccentBrush}"
                                    RadiusX="2"
                                    RadiusY="2" />

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        TextTrimming="CharacterEllipsis"
                                        u:HighlightedText.Segments="{Binding TitleSegments}" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="12"
                                        Foreground="#666"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap"
                                        u:HighlightedText.Segments="{Binding ExcerptSegments}" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="11"
                                        Foreground="#1976D2"
                                        Visibility="{Binding TagsLine, Converter={StaticResource NonEmptyToVis}}"
                                        u:HighlightedText.Segments="{Binding TagSegments}" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="2"
                                    VerticalAlignment="Top"
                                    Orientation="Horizontal">
                                    <StackPanel Margin="0,2,8,0" HorizontalAlignment="Right">
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="#999"
                                            HorizontalAlignment="Right"
                                            Text="{Binding ModifiedAt, StringFormat=g}"
                                            Visibility="{Binding IsTrashed, Converter={StaticResource InverseBoolToVis}}" />
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="#B85C5C"
                                            HorizontalAlignment="Right"
                                            Text="{Binding DeletedAt, StringFormat=삭제됨 g}"
                                            Visibility="{Binding IsTrashed, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>

                                    <!-- 활성 카드: Delete (휴지통으로) -->
                                    <Button
                                        Padding="6,1"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Content="Delete"
                                        Visibility="{Binding IsTrashed, Converter={StaticResource InverseBoolToVis}}" />

                                    <!-- 휴지통 카드: 복원 / 영구삭제 -->
                                    <Button
                                        Padding="6,1"
                                        Margin="0,0,4,0"
                                        Background="#E3F2FD"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Content="복원"
                                        Cursor="Hand"
                                        Visibility="{Binding IsTrashed, Converter={StaticResource BoolToVis}}" />
                                    <Button
                                        Padding="6,1"
                                        Background="#FBE9E7"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.PurgeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Content="영구삭제"
                                        Cursor="Hand"
                                        Visibility="{Binding IsTrashed, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock
                Margin="0,40,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                FontSize="13"
                Foreground="#888"
                Text="{Binding EmptyMessage}"
                Visibility="{Binding Items.Count, Converter={StaticResource ZeroToVis}}" />
        </Grid>

        <DockPanel Grid.Row="5" Margin="0,8,0,0">
            <Button
                Padding="10,3"
                Command="{Binding ClearTagCommand}"
                Content="Clear tag filter"
                IsEnabled="{Binding ActiveTag, Converter={StaticResource NonNullToBool}}" />
            <TextBlock
                Margin="10,0,0,0"
                VerticalAlignment="Center"
                Foreground="#888"
                Text="{Binding ActiveTag, StringFormat=Tag: #{0}}" />
            <TextBlock
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Foreground="#888"
                Text="Ctrl+Shift+L to toggle • Esc to close" />
        </DockPanel>
    </Grid>
</Window>
