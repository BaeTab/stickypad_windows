<Window
    x:Class="StickyPad.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="StickyPad — Settings"
    Width="400"
    Height="380"
    Background="#FAFAFA"
    FontFamily="Segoe UI"
    ResizeMode="NoResize"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            FontSize="18"
            FontWeight="SemiBold"
            Text="설정" />

        <CheckBox
            Grid.Row="1"
            Margin="0,16,0,0"
            Content="Windows 시작 시 자동 실행"
            IsChecked="{Binding AutoStartWithWindows}" />

        <CheckBox
            Grid.Row="2"
            Margin="0,12,0,0"
            Content="새 버전 자동 확인 (GitHub 릴리즈)"
            IsChecked="{Binding AutoCheckForUpdates}" />

        <CheckBox
            Grid.Row="3"
            Margin="0,12,0,0"
            Content="전역 단축키 사용"
            IsChecked="{Binding GlobalHotkeysEnabled}" />

        <Grid Grid.Row="4" Margin="0,14,0,0" IsEnabled="{Binding GlobalHotkeysEnabled}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="새 노트" />
            <TextBox
                x:Name="NewNoteBox"
                Grid.Column="1"
                Height="30"
                Padding="8,5"
                VerticalContentAlignment="Center"
                IsReadOnly="True"
                PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                Text="{Binding NewNoteHotkey, Mode=OneWay}" />
        </Grid>

        <Grid Grid.Row="5" Margin="0,10,0,0" IsEnabled="{Binding GlobalHotkeysEnabled}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="전체 목록" />
            <TextBox
                x:Name="NotesListBox"
                Grid.Column="1"
                Height="30"
                Padding="8,5"
                VerticalContentAlignment="Center"
                IsReadOnly="True"
                PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                Text="{Binding NotesListHotkey, Mode=OneWay}" />
        </Grid>

        <TextBlock
            Grid.Row="6"
            Margin="0,8,0,0"
            FontSize="11"
            Foreground="#888"
            Text="입력란을 클릭한 뒤 원하는 조합키를 누르세요 (예: Ctrl+Shift+N)." />

        <TextBlock
            Grid.Row="7"
            Margin="0,10,0,0"
            VerticalAlignment="Top"
            FontSize="12"
            Foreground="#C62828"
            Text="{Binding ValidationError}"
            TextWrapping="Wrap" />

        <StackPanel
            Grid.Row="8"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="80"
                Margin="0,0,8,0"
                Padding="10,5"
                Click="Cancel_OnClick"
                Content="취소"
                IsCancel="True" />
            <Button
                Width="80"
                Padding="10,5"
                Command="{Binding SaveCommand}"
                Content="저장"
                IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
