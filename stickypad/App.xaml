<Application x:Class="StickyPad.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:u="clr-namespace:StickyPad.Utils">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <u:NoteColorEqualsConverter x:Key="ColorEquals" />
            <u:ColorToBrushConverter x:Key="ColorToBrush" />
            <u:InverseBoolConverter x:Key="InverseBool" />
            <u:NonEmptyStringToVisibilityConverter x:Key="NonEmptyToVis" />
            <u:NonNullToBoolConverter x:Key="NonNullToBool" />
            <u:BoolToVisibilityConverter x:Key="BoolToVis" />
            <u:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
            <u:ZeroCountToVisibilityConverter x:Key="ZeroToVis" />
            <u:ViewModeToVisibilityConverter x:Key="ViewModeToVis" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
